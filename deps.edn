{:deps {io.github.dfornika/ncbi-api-client-clj
        {:git/url "https://github.com/dfornika/ncbi-api-client-clj.git"
         :git/sha "a79fee55aa2d88cdfdce6351cc431521f11170bd"}}

 :paths ["src/main"]

 :aliases
 {:dev {:extra-paths ["src/dev"]}
  :nrepl {:extra-deps {nrepl/nrepl {:mvn/version "1.7.0"}
                       ch.qos.logback/logback-classic {:mvn/version "1.5.34"}}
          :jvm-opts ["-Djdk.attach.allowAttachSelf"]
          :main-opts ["-m" "nrepl.cmdline" "--port" "7888"]}}}
